# Chiavi API dei LLM
GROQ_API_KEY=inserisci_qui_la_tua_api_key_groq

# Configurazione OpenFoodFacts (Richiede un User-Agent per policy)
OPENFOODFACTS_APP_NAME=RepEats_University_Project_v1

# Configurazione Database Locale
# Usata sia dall'applicazione sia da Alembic (le migrazioni leggono questa
# stessa variabile via alembic/env.py). Deve essere sempre valorizzata.
DATABASE_URL=sqlite:///repeats_local.db

# Autenticazione JWT (Bearer token)
# JWT_SECRET_KEY: chiave segreta per firmare i token. In produzione usare una
# stringa lunga e casuale (es. `openssl rand -hex 32`). NON committare quella reale.
JWT_SECRET_KEY=cambia_questa_con_una_stringa_segreta_casuale_molto_lunga
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30